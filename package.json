{
  "name": "claude-slack-channel",
  "version": "0.1.0",
  "description": "Claude Code Channel MCP server for Slack — bidirectional interactive bridge via Socket Mode",
  "type": "module",
  "main": "src/server.ts",
  "bin": {
    "claude-slack-channel": "src/server.ts"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "bun run src/server.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "prepublishOnly": "bunx tsc --noEmit && bun test"
  },
  "files": [
    "src",
    "!src/__tests__",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "license": "MIT",
  "keywords": [
    "claude-code",
    "mcp",
    "slack",
    "channel",
    "mcp-server",
    "automation"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@slack/socket-mode": "^2.0.6",
    "@slack/web-api": "^7.15.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/bun": "1.3.11",
    "typescript": "6.0.2"
  }
}
