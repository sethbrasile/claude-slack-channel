# claude-slack-channel environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Required: Bot token for posting messages and reading channel history.
# Found in: Slack App Settings > OAuth & Permissions > Bot User OAuth Token
# Format: starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Required: App-level token for Socket Mode WebSocket connection.
# Found in: Slack App Settings > Basic Information > App-Level Tokens
# Format: starts with xapp- (token must have the connections:write scope)
SLACK_APP_TOKEN=xapp-your-app-token-here

# Required: The Slack channel ID to listen and respond in.
# Format: C0XXXXXXXXX (capital C followed by alphanumeric characters)
# How to find it: right-click the channel in Slack > Copy link
#   The ID is the last segment: https://yourworkspace.slack.com/archives/C0XXXXXXXXX
SLACK_CHANNEL_ID=C0XXXXXXXXX

# Required: Comma-separated list of Slack user IDs allowed to send commands.
# Format: Slack user IDs matching /^[UW][A-Z0-9]+$/ (e.g. U0XXXXXXXXX)
# How to find a member ID: click their profile > ... (More) > Copy member ID
# Multiple IDs: ALLOWED_USER_IDS=U0XXXXXXXXX,U0YYYYYYYYY
ALLOWED_USER_IDS=U0XXXXXXXXX

# Optional: Identifier for this server instance shown in Claude's context.
# Default: slack
# Use a project-specific name when running multiple instances on the same machine
# to help Claude distinguish which channel/project each server belongs to.
# SERVER_NAME=my-project
SERVER_NAME=slack
